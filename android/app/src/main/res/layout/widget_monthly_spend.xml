<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_monthly_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_card_bg"
  android:orientation="vertical"
  android:padding="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/widget_monthly_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="This month"
      android:textColor="@color/widget_title"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_monthly_amount"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="10dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Rs 0"
      android:textColor="@color/widget_button_expense_icon"
      android:textSize="17sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/widget_monthly_empty"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Add a few expenses to see this widget come alive."
    android:textColor="@color/widget_text_secondary"
    android:textSize="12sp"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/widget_monthly_category_list"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="vertical">

    <LinearLayout
      android:id="@+id/widget_monthly_row_1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Food"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_monthly_row_2"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Shopping"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_monthly_row_3"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Bills"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_monthly_row_4"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Travel"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_monthly_row_5"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Health"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/widget_monthly_row_6"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingVertical="2dp">

      <TextView
        android:id="@+id/widget_monthly_name_6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Other"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp" />

      <TextView
        android:id="@+id/widget_monthly_value_6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs 0"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>
