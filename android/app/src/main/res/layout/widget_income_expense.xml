<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_income_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_card_bg"
  android:orientation="vertical"
  android:padding="16dp">

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Income vs Expense"
    android:textColor="@color/widget_title"
    android:textSize="12sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_income_period"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="This month"
    android:textColor="@color/widget_text_primary"
    android:textSize="16sp" />

  <TextView
    android:id="@+id/widget_income_empty"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:text="Transactions will show your income and expenses here."
    android:textColor="@color/widget_text_secondary"
    android:textSize="13sp"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/widget_income_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Income"
          android:textColor="@color/widget_button_income_icon"
          android:textSize="12sp" />

        <TextView
          android:id="@+id/widget_income_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="₹0"
          android:textColor="@color/widget_button_income_icon"
          android:textSize="22sp"
          android:textStyle="bold" />
      </LinearLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Expense"
          android:textColor="@color/widget_button_expense_icon"
          android:textSize="12sp" />

        <TextView
          android:id="@+id/widget_expense_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="₹0"
          android:textColor="@color/widget_button_expense_icon"
          android:textSize="22sp"
          android:textStyle="bold" />
      </LinearLayout>
    </LinearLayout>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="16dp"
      android:background="@color/widget_divider"
      android:text="" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:text="Net"
      android:textColor="@color/widget_title"
      android:textSize="12sp" />

    <TextView
      android:id="@+id/widget_net_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:text="₹0"
      android:textColor="@color/widget_text_primary"
      android:textSize="24sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
