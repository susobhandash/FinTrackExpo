<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_income_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_card_bg"
  android:gravity="center_vertical"
  android:orientation="vertical"
  android:padding="10dp">

  <TextView
    android:id="@+id/widget_income_period"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="This month"
    android:textColor="@color/widget_title"
    android:textSize="11sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_income_empty"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Transactions will show your income and expenses here."
    android:textColor="@color/widget_text_secondary"
    android:textSize="12sp"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/widget_income_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:baselineAligned="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:weightSum="2">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:background="@drawable/widget_button_income"
      android:gravity="center_vertical"
      android:minHeight="36dp"
      android:orientation="horizontal"
      android:paddingStart="10dp"
      android:paddingTop="8dp"
      android:paddingEnd="10dp"
      android:paddingBottom="8dp">

      <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_widget_income"
        android:tint="@color/widget_button_icon_on_color" />

      <TextView
        android:id="@+id/widget_income_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Rs 0"
        android:textColor="@color/widget_button_icon_on_color"
        android:textSize="14sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="10dp"
      android:layout_weight="1"
      android:background="@drawable/widget_button_expense"
      android:gravity="center_vertical|end"
      android:minHeight="36dp"
      android:orientation="horizontal"
      android:paddingStart="10dp"
      android:paddingTop="8dp"
      android:paddingEnd="10dp"
      android:paddingBottom="8dp">

      <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_widget_expense"
        android:tint="@color/widget_button_icon_on_color" />

      <TextView
        android:id="@+id/widget_expense_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:gravity="end"
        android:maxLines="1"
        android:text="Rs 0"
        android:textColor="@color/widget_button_icon_on_color"
        android:textSize="14sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>
